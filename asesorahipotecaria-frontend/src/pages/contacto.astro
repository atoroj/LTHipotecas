---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
---

<Layout title="Contacto |">
  <main class="py-10 px-4 md:px-6 lg:px-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div
          class="lg:sticky lg:top-8 lg:pt-4 text-gray-800 dark:text-gray-200"
        >
          <h1
            class="text-4xl font-extrabold mb-4 dark:text-white"
            transition:name="contacto-titulo"
            transition:animate="slide"
          >
            Hablemos de tu <span class="text-blue-600 dark:text-blue-400"
              >futuro financiero</span
            >
          </h1>

          <p
            class="text-lg text-gray-600 dark:text-gray-400 mb-6 border-l-4 border-blue-500 pl-4"
          >
            Detrás de cada hipoteca hay una historia. Empezamos por la tuya.
          </p>

          <p class="mb-6">
            Acompaño a personas que quieren conseguir una hipoteca, ya se para
            su vivienda habital, vivienda de inversión, como autónomos o en
            situaciones más complejas, como hipotecas al 100% o reunificaciones
            de deuda.
          </p>

          <p class="mb-6">
            Si estás valorando una operación hipotecaria y quieres saber si tu
            caso es viable, puedes escribirme y contarme brevemente tu
            situación.
          </p>

          <p class="mb-6">
            Revisaré tu mensaje y, si encaja, concertaremos una llamada para
            analizarlo con más detalle
          </p>

          <h2 class="text-2xl font-semibold mb-4 text-gray-900 dark:text-white">
            Contacto Directo
          </h2>
          <ul class="space-y-4 text-gray-700 dark:text-gray-300">
            <li class="flex items-center">
              <svg
                class="w-6 h-6 mr-3 text-blue-500"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path></svg
              >
              <div>
                <span class="font-medium">Email de Soporte</span><br />
                <a
                  href="mailto:info@ejemplo.com"
                  class="hover:text-blue-600 transition">info@ejemplo.com</a
                >
              </div>
            </li>
            <li class="flex items-center">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 mr-3 text-green-600"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.432 5.63 1.433h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                ></path>
              </svg>
              <div>
                <span class="font-medium">Whatsapp</span><br />
                <a
                  href="https://wa.me/34666666666"
                  class="hover:text-blue-600 transition"
                  >Escríbeme por Whatsapp y cuéntame tu caso</a
                >
              </div>
            </li>
          </ul>
        </div>

        <div>
          <ContactForm />
        </div>
      </div>
    </div>
  </main>
</Layout>
