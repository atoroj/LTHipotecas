---
import Layout from "../layouts/Layout.astro";
import StepCard from "../components/StepCard.astro"; // Asegúrate de que la ruta sea correcta
import BankLogos from "../components/BankLogos.astro";

const steps = [
  {
    step: "1",
    title: "Evaluación inicial",
    description:
      "Analizamos tu punto de partida, situación financiera y objetivos, para plantear la operación con criterio profesional.",
  },
  {
    step: "2",
    title: "Planteamiento y negociación",
    description:
      "Preparamos tu expediente con visión financiera y gestionamos la negociación con las entidades bancarias.",
  },
  {
    step: "3",
    title: "Firma de hipoteca",
    description:
      "Te acompañamos hasta el día de la firma, controlando que todo esté a punto para que la hipoteca se cierre con calma y tranquilidad.",
  },
];
---

<Layout title="Inicio | Tu Broker Hipotecario">
  <main class="py-10">
    <div class="container mx-auto px-4">
      <div class="flex flex-col items-center text-center">
        <h1
          class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-gray-900 dark:text-white leading-tight tracking-tight"
        >
          Expertos en <br class="block md:hidden" />
          <span
            class="text-rotate inline-grid h-[1.2em] text-blue-600 dark:text-blue-400"
          >
            <span class="justify-items-center">
              <span>HIPOTECAS 100%</span>
              <span>HIPOTECAS INVERSIÓN</span>
              <span>HIPOTECAS PARA AUTONOMOS</span>
              <span>REUNIFICACIÓN</span>
              <span>HIPOTECAS PARA JÓVENES</span>
            </span>
          </span>
        </h1>

        <p
          class="mt-8 max-w-2xl text-lg md:text-xl text-gray-600 dark:text-gray-400"
        >
          No se trata solo de conseguir una hipoteca. Analizamos tu situación y
          te acompañamos en cada paso del proceso para que firmes la hipoteca
          que mejor se adapta a ti, con tranquilidad y confianza.
        </p>

        <div class="mt-12">
          <div class="mb-8 text-center md:text-left">
            <p
              class="text-lg font-bold text-gray-400 uppercase tracking-widest mb-2"
            >
              Escríbenos
            </p>
            <h2
              class="text-xs md:text-xl font-bold text-gray-900 dark:text-white"
            >
              Cuéntanos tu caso y veremos cómo ayudarte
            </h2>
          </div>

          <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12">
            <a href="https://wa.me/34611171945" class="flex items-center group">
              <div
                class="bg-[#25D366] p-3 rounded-full text-white group-hover:bg-[#20ba5a] transition-colors shadow-lg shadow-green-600/20"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.432 5.63 1.433h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                  ></path>
                </svg>
              </div>
              <div class="ml-4 text-left">
                <p
                  class="text-xs font-bold text-gray-400 uppercase tracking-widest"
                >
                  WhatsApp
                </p>
                <p
                  class="text-base md:text-lg font-bold text-gray-900 dark:text-white"
                >
                  +34 611 17 19 45
                </p>
              </div>
            </a>

            <a
              href="mailto:info@lthipotecas.com"
              class="flex items-center group"
            >
              <div
                class="bg-gray-100 dark:bg-gray-800 p-3 rounded-full text-blue-600 group-hover:bg-blue-50 dark:group-hover:bg-gray-700 transition-colors border border-gray-200 dark:border-gray-700"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
              <div class="ml-4 text-left">
                <p
                  class="text-xs font-bold text-gray-400 uppercase tracking-widest"
                >
                  Email
                </p>
                <p
                  class="text-base md:text-lg font-bold text-gray-900 dark:text-white"
                >
                  info@lthipotecas.com
                </p>
              </div>
            </a>
          </div>
        </div>
        <section class="">
          <div class="mt-24 w-full max-w-6xl mx-auto px-4 text-center mb-16">
            <h2
              class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white tracking-tight"
            >
              Tu camino hacia la mejor hipoteca
            </h2>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 lg:gap-8">
            {
              steps.map((item, index) => (
                <StepCard
                  step={item.step}
                  title={item.title}
                  description={item.description}
                  isLast={index === steps.length - 1}
                />
              ))
            }
          </div>
        </section>
        <BankLogos />
        <div
          class="w-full max-w-4xl border-t border-gray-200 dark:border-gray-800 pt-12"
        >
          <div class="grid grid-cols-1 md:grid-cols-2 items-center gap-10">
            <div class="text-left space-y-4">
              <div
                class="inline-flex items-center space-x-2 text-blue-600 dark:text-blue-400 font-bold text-sm tracking-wider uppercase"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path
                    fill-rule="evenodd"
                    d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
                <span>Entidad Regulada</span>
              </div>

              <p
                class="text-gray-600 dark:text-gray-400 text-md leading-relaxed"
              >
                Operamos bajo la estricta supervisión del <strong
                  >Banco de España</strong
                >. Estamos inscritos como Intermediarios de Crédito Inmobiliario
                según la <strong>Ley 05/2019</strong>, lo que garantiza
                transparencia total en tu gestión.
              </p>
            </div>

            <div class="flex justify-center md:justify-end">
              <div
                class="bg-white p-6 rounded-2xl shadow-xl shadow-gray-200/50 dark:shadow-none border border-gray-100 dark:bg-white transition-transform hover:scale-105 duration-300"
              >
                <img
                  src="/Registro-banco-de-espana.png"
                  alt="Registro Banco de España Nº 2019/D641"
                  class="h-9 md:h-11 w-auto"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
