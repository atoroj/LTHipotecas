---
interface Props {
  currentPath: string;
}

// Recibimos la propiedad 'links' desde el Layout
const { currentPath } = Astro.props;
const isActive = (url_slug: string) => {
  return url_slug === currentPath || (url_slug === "/" && currentPath === "/");
};

const inactiveClasses =
  "font-medium text-gray-800 hover:text-blue-600 py-3 md:py-6 dark:text-gray-200 dark:hover:text-blue-500";
const activeClasses =
  "font-medium text-blue-600 border-b-2 border-blue-600 py-3 md:py-6 dark:text-blue-500 dark:border-blue-500";
---

<header
  class="flex flex-wrap md:justify-start md:flex-nowrap z-50 w-full bg-gray-50 text-sm py-3 md:py-0 dark:bg-gray-800"
>
  <div
    class="max-w-340 w-full mx-auto px-4 md:px-6 lg:px-12"
    aria-label="Global"
  >
    <div class="relative md:flex md:items-center md:justify-between">
      <div class="flex items-center justify-between">
        <a
          class="flex-none text-xl font-semibold dark:text-white flex items-center gap-x-3"
          href="/"
          aria-label="Brand"
        >
          <span class="text-blue-600 dark:text-blue-500">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="50"
              height="50"
              viewBox="0 0 400.5 400.5"
              preserveAspectRatio="xMidYMid meet"
              class="text-blue-600 dark:text-blue-400 transition-transform group-hover:scale-110"
            >
              <path
                fill="currentColor"
                d="M 189.886719 22.257812 C 181.699219 28.335938 104.992188 83.320312 66.292969 110.851562 C 46.722656 124.777344 38.042969 130.984375 30.148438 136.707031 L 22.472656 142.277344 L 22.472656 383.519531 L 89.699219 383.566406 C 236.894531 383.660156 378.578125 383.421875 379.132812 383.078125 C 379.457031 382.878906 379.648438 343.375 379.5625 295.292969 L 379.402344 207.867188 L 365.355469 207.660156 L 351.3125 207.457031 L 351.304688 278.449219 C 351.296875 317.492188 351.085938 350.703125 350.832031 352.246094 L 350.367188 355.058594 L 51.683594 355.058594 L 51.679688 338.765625 C 51.679688 329.804688 51.457031 285.019531 51.1875 239.242188 L 50.703125 156.015625 L 66.363281 144.902344 C 83.648438 132.636719 137.429688 94.023438 168.914062 71.265625 C 180.039062 63.226562 191.710938 54.867188 194.851562 52.683594 L 200.566406 48.714844 L 208.710938 54.554688 C 227.761719 68.21875 334.132812 144.15625 355.582031 159.410156 C 368.4375 168.550781 379.226562 176.03125 379.554688 176.03125 C 380.472656 176.035156 379.546875 142.363281 378.609375 141.730469 C 377.421875 140.929688 353.4375 123.824219 338.578125 113.183594 C 325.328125 103.710938 312.097656 94.230469 298.875 84.738281 C 281.371094 72.203125 263.859375 59.667969 246.339844 47.140625 C 232.070312 36.9375 216.257812 25.53125 211.199219 21.789062 C 206.144531 18.042969 201.472656 14.992188 200.816406 15.003906 C 200.160156 15.019531 195.242188 18.28125 189.886719 22.257812 M 97.378906 146.742188 L 94.007812 147.191406 L 93.816406 235.019531 L 93.628906 322.847656 L 129.839844 322.847656 C 149.757812 322.847656 172.683594 322.625 180.792969 322.351562 L 195.535156 321.859375 L 195.332031 305.75 L 195.132812 289.640625 L 125.335938 290 L 124.882812 255.625 C 124.636719 236.722656 124.636719 204.792969 124.882812 184.675781 C 125.316406 149.648438 125.277344 148.054688 123.949219 147.082031 C 122.914062 146.324219 119.792969 146.097656 111.65625 146.179688 C 105.65625 146.242188 99.230469 146.496094 97.378906 146.742188 M 172.035156 146.566406 C 171.761719 146.839844 171.535156 154.257812 171.535156 163.046875 L 171.535156 179.027344 L 180.335938 179.066406 C 185.179688 179.085938 196.636719 179.070312 205.800781 179.027344 L 222.464844 178.953125 L 222.65625 250.710938 L 222.847656 322.472656 L 225.09375 322.734375 C 226.328125 322.878906 233.875 322.757812 241.863281 322.460938 L 256.382812 321.925781 L 255.828125 282 C 255.527344 260.042969 255.527344 227.890625 255.832031 210.550781 L 256.382812 179.027344 L 309.363281 179.027344 L 309.363281 163.445312 C 309.363281 152.328125 309.105469 147.609375 308.464844 146.964844 C 307.777344 146.28125 291.5625 146.066406 240.050781 146.066406 C 202.917969 146.066406 172.308594 146.292969 172.035156 146.566406"
              ></path>
            </svg>
          </span>

          <span class="text-2xl">Asesoría Hipotecaria</span>
        </a>
        <div class="md:hidden">
          <button
            type="button"
            class="hs-collapse-toggle p-2 inline-flex justify-center items-center gap-2 rounded-md border bg-gray-100 text-gray-500 shadow-sm align-middle hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-white focus:ring-blue-600 transition-all text-sm dark:bg-slate-900 dark:hover:bg-slate-800 dark:border-gray-700 dark:text-gray-400 dark:hover:text-white dark:focus:ring-offset-gray-800"
            data-hs-collapse="#navbar-collapse-with-animation"
            aria-controls="navbar-collapse-with-animation"
            aria-label="Toggle navigation"
          >
            <svg
              class="hs-collapse-open:hidden w-4 h-4"
              width="16"
              height="16"
              fill="currentColor"
              viewBox="0 0 16 16"
            >
              <path
                fill-rule="evenodd"
                d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z"
              ></path>
            </svg>
            <svg
              class="hs-collapse-open:block hidden w-4 h-4"
              width="16"
              height="16"
              fill="currentColor"
              viewBox="0 0 16 16"
            >
              <path
                d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"
              ></path>
            </svg>
          </button>
        </div>
      </div>

      <div
        id="navbar-collapse-with-animation"
        class="hs-collapse hidden overflow-hidden transition-all duration-300 basis-full grow md:block"
      >
        <div class="overflow-hidden overflow-y-auto max-h-[75vh] scrollbar-y">
          <div
            class="flex flex-col gap-x-0 mt-5 divide-y divide-dashed divide-gray-200 md:flex-row md:items-center md:justify-end md:gap-x-7 md:mt-0 md:pl-7 md:divide-y-0 md:divide-solid dark:divide-gray-700"
          >
            <a
              class={isActive("/") ? activeClasses : inactiveClasses}
              href="/"
              aria-current={isActive("/") ? "page" : undefined}>Inicio</a
            >

            <a
              class={isActive("/sobre-mi") ? activeClasses : inactiveClasses}
              href="/sobre-mi"
            >
              Sobre mí
            </a>
            <a
              class={isActive("/testimonios") ? activeClasses : inactiveClasses}
              href="/testimonios"
            >
              Testimonios
            </a>

            <div class="pt-3 md:pt-0">
              <a
                class="inline-flex justify-center items-center gap-x-2 text-center bg-blue-600 hover:bg-blue-700 border border-transparent text-white text-sm font-medium rounded-md focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2 focus:ring-offset-white transition py-2.5 px-3 dark:focus:ring-offset-gray-800"
                href="/contacto"
              >
                Contacto
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
