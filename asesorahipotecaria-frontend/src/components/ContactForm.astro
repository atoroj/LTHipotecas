<div class="max-w-xl mx-auto p-8 bg-white shadow-xl rounded-lg">
  <h2 class="text-3xl font-bold mb-6">Contáctanos</h2>

  <form
    method="POST"
    action="#"
    class="space-y-6"
    aria-label="Formulario de contacto"
  >
    <div>
      <label for="name" class="block text-sm font-medium mb-1"> Nombre </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500 transition duration-150 ease-in-out"
        placeholder="Tu nombre completo"
      />
    </div>

    <div>
      <label for="phone" class="block text-sm font-medium mb-1">
        Teléfono
      </label>
      <input
        type="tel"
        id="phone"
        name="phone"
        required
        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500 transition duration-150 ease-in-out"
        placeholder="Número de teléfono"
      />
    </div>
    <div>
      <label for="email" class="block text-sm font-medium mb-1">
        Correo Electrónico
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500 transition duration-150 ease-in-out"
        placeholder="ejemplo@dominio.com"
      />
    </div>

    <div>
      <label for="message" class="block text-sm font-medium mb-1">
        Mensaje
      </label>
      <textarea
        id="message"
        name="message"
        rows="4"
        required
        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500 resize-none transition duration-150 ease-in-out"
        placeholder="Cuéntame brevemente tu situación (tipo de operación, momento en el que estás, situación laboral y cualquier dato que consideres importante)"
      ></textarea>
    </div>

    <div class="pt-2">
      <button
        type="submit"
        class="w-full flex justify-center py-3 px-6 border border-transparent rounded-md shadow-sm text-lg font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition duration-150 ease-in-out transform hover:scale-[1.01]"
      >
        Enviar Mensaje
      </button>
    </div>
  </form>
</div>
