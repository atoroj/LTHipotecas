---
import ReviewCard from "../ReviewCard.astro";

const reviews = [
  {
    name: "Carlos Rodríguez",
    role: "Hipoteca Primera Vivienda",
    content:
      "Gracias a su gestión conseguí un tipo de interés que mi banco de toda la vida me negaba. Profesionales y muy transparentes.",
    stars: 5,
    avatar:
      "https://ui-avatars.com/api/?name=Carlos+Rodriguez&background=0D8ABC&color=fff",
  },
  {
    name: "Marta Jiménez",
    role: "Reestructuración de Deuda",
    content:
      "Excelente trato. Me explicaron cada cláusula del contrato y me acompañaron hasta la firma en notaría. Muy recomendables.",
    stars: 5,
    avatar:
      "https://ui-avatars.com/api/?name=Marta+Jimenez&background=0D8ABC&color=fff",
  },
  {
    name: "Juan Portero",
    role: "Inversión Inmobiliaria",
    content:
      "Buscaba rapidez para una oportunidad de inversión y cumplieron con creces. Conocen el mercado hipotecario a la perfección.",
    stars: 5,
    avatar:
      "https://ui-avatars.com/api/?name=Juan+Portero&background=0D8ABC&color=fff",
  },
];
---

<section class="py-20 px-4 md:px-6 lg:px-12">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-extrabold sm:text-4xl">
        La confianza de nuestros <span class="text-blue-600 dark:text-blue-400"
          >clientes</span
        >
      </h2>
      <p
        class="mt-4 text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto"
      >
        Ayudamos a personas reales a conseguir las mejores condiciones para su
        futuro.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {reviews.map((review) => <ReviewCard {...review} />)}
    </div>
  </div>
</section>
