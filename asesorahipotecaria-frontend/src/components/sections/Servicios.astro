---
// src/components/sections/ServicesTrust.astro
import StepCard from "../StepCard.astro";
import BankLogos from "../BankLogos.astro";

const steps = [
  {
    step: "1",
    title: "Evaluación inicial",
    description:
      "Analizamos tu punto de partida, situación financiera y objetivos, para plantear la operación con criterio profesional.",
  },
  {
    step: "2",
    title: "Planteamiento y negociación",
    description:
      "Preparamos tu expediente con visión financiera y gestionamos la negociación con las entidades bancarias.",
  },
  {
    step: "3",
    title: "Firma de hipoteca",
    description:
      "Te acompañamos hasta el día de la firma, controlando que todo esté a punto para que la hipoteca se cierre con calma y tranquilidad.",
  },
];
---

<section class="pt-20 px-4 md:px-6 lg:px-12">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl pb-10 font-bold tracking-tight">
      Tu camino hacia la mejor hipoteca
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 lg:gap-8">
      {
        steps.map((item, index) => (
          <StepCard
            step={item.step}
            title={item.title}
            description={item.description}
            isLast={index === steps.length - 1}
          />
        ))
      }
    </div>

    <BankLogos />

    <div
      class="w-full border-t border-gray-200 dark:border-gray-800 pt-12 mx-auto"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 items-center gap-10">
        <div class="text-left space-y-4">
          <div
            class="inline-flex items-center space-x-2 text-blue-600 dark:text-blue-400 font-bold text-sm tracking-wider uppercase"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 20 20"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                clip-rule="evenodd"></path>
            </svg>
            <span>Entidad Regulada</span>
          </div>

          <p class="text-md leading-relaxed">
            Operamos bajo la estricta supervisión del <strong
              >Banco de España</strong
            >. Estamos inscritos como Intermediarios de Crédito Inmobiliario
            según la <strong>Ley 05/2019</strong>, lo que garantiza
            transparencia total en tu gestión.
          </p>
        </div>

        <div class="flex justify-center md:justify-end text-left">
          <div
            class="bg-white p-6 rounded-2xl shadow-xl shadow-gray-200/50 dark:shadow-none border border-gray-100 dark:bg-gray-700 transition-transform hover:scale-105 duration-300 flex items-center space-x-4"
          >
            <div class="flex flex-col">
              <span class="text-xl md:text-2xl font-bold">BANCO DE ESPAÑA</span>
              <span class="text-sm text-gray-500 dark:text-gray-500"
                >Eurosistema</span
              >
            </div>
            <div class="h-12 border-l-2 border-gray-300 dark:border-gray-300">
            </div>
            <div
              class="flex flex-col text-sm text-gray-600 dark:text-gray-100 font-medium"
            >
              <span>Registro Nº E461</span>
              <span>según Intermediarios de Créditos Inmobiliarios</span>
              <span>según Ley 05/2019</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
