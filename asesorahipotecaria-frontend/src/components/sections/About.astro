---
import { Image } from "astro:assets";
import fotoPerfil from "../../assets/aboutme.png";
import { getEntry } from "astro:content";

const sobreMi = await getEntry("about", "sobre-mi");

if (!sobreMi) {
  throw new Error("No se encontro el archivo sobre-mi");
}

const { data, render } = sobreMi;
const { Content } = await render();
---

<section class="py-20 px-4 md:px-6 lg:px-12">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
      <div class="lg:col-span-2 text-center lg:text-left">
        <h2 class="text-5xl font-bold">{data.title}</h2>
        <h3
          class="text-3xl font-semibold mt-4 text-blue-600 dark:text-blue-400"
        >
          {data.subtitle}
        </h3>
        <p class="pt-2 leading-relaxed space-y-4 text-lg">
          <Content />
        </p>

        <h2 class="pt-4 text-2xl font-bold leading-relaxed">
          {data.title_experiencia}
        </h2>
        <ul class="space-y-4 text-lg mt-4 text-left inline-block">
          {
            data.experiencia.map((item) => (
              <li class="flex items-start">
                <span class="mr-3 text-blue-600 mt-1">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="lg:col-span-1 flex justify-center items-center py-8">
        <div class="relative">
          <div
            class="absolute -inset-4 bg-gradient-to-r from-blue-600 to-cyan-600 rounded-lg opacity-30 blur-lg"
          >
          </div>
          <Image
            src={fotoPerfil}
            alt={`Foto de ${data.name}`}
            class="relative max-w-sm rounded-lg shadow-2xl object-cover w-80 h-96"
          />
        </div>
      </div>
    </div>
  </div>
</section>
